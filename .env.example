# =============================================================================
# V1 required (docs/architecture/backend-architecture.md § Environment)
# =============================================================================

# Prisma pooled connection string (Supabase PostgreSQL)
DATABASE_URL=

# Prisma direct connection string for migrations
DIRECT_URL=

# Signing secret for admin JWT cookies (use a long random string)
JWT_SECRET=

# Canonical site URL (SEO, absolute links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Runtime environment: development | production | test
NODE_ENV=development

# =============================================================================
# Seed credentials (prisma/seed.ts) — local script only
# =============================================================================
# Used when you run `npx prisma db seed` against your database.
# After seed, the Test Admin User row lives in the DB — that same account can
# sign in on Vercel when DATABASE_URL points at this database.
# You do NOT need SEED_ADMIN_* as Vercel runtime env vars for login.
# Do not commit real passwords. Seed refuses NODE_ENV=production.

# Test Admin email (example: admin@example.com)
SEED_ADMIN_EMAIL=

# Strong password — never commit real values
SEED_ADMIN_PASSWORD=

# Display name for the seeded admin (optional; defaults to "Test Admin")
SEED_ADMIN_NAME=Test Admin

# =============================================================================
# Email OTP MFA (optional — enabled when both RESEND_API_KEY and MFA_NOTIFY_EMAIL are set)
# =============================================================================
# Login identity stays the Test Admin email/password.
# OTP codes are delivered to MFA_NOTIFY_EMAIL (your real inbox), not User.email.

# Resend API key (https://resend.com)
RESEND_API_KEY=

# Verified sender address in Resend (e.g. onboarding@resend.dev or your domain)
RESEND_FROM_EMAIL=

# Real inbox that receives MFA codes
MFA_NOTIFY_EMAIL=

# =============================================================================
# Deferred (not required for V1)
# =============================================================================
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=
