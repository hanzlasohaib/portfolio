# =============================================================================
# V1 required (docs/architecture/backend-architecture.md § Environment)
# =============================================================================

# Prisma pooled connection string (Supabase PostgreSQL)
DATABASE_URL=

# Prisma direct connection string for migrations
DIRECT_URL=

# Signing secret for admin JWT cookies (use a long random string)
JWT_SECRET=

# Canonical site URL (SEO, absolute links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Runtime environment: development | production | test
NODE_ENV=development

# =============================================================================
# Development-only seed (prisma/seed.ts) — do NOT use in production
# =============================================================================

# Test Admin email (example: admin@example.com)
SEED_ADMIN_EMAIL=

# Strong password stored only in local .env — never commit real values
SEED_ADMIN_PASSWORD=

# Display name for the seeded admin (optional; defaults to "Test Admin")
SEED_ADMIN_NAME=Test Admin

# =============================================================================
# Deferred (not required for V1)
# =============================================================================
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# RESEND_API_KEY=
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=
